# GSTD Contract Deployment — Environment Variables
# Copy to .env and fill in ALL values. NEVER commit .env.

# 24-word mnemonic for the deployer wallet (needs >= 5 TON for gas)
DEPLOYER_MNEMONIC="word1 word2 word3 ... word24"

# Contract owner — use multisig in production, your wallet for Phase 1
ADMIN_WALLET="EQxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Gateway = backend wallet that calls SettlementMaster.SettleTask
# Phase 1: hot wallet of app.gstdtoken.com backend
GATEWAY_ADDRESS="EQxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Initial allocation wallets
TEAM_WALLET="EQxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
ECOSYSTEM_WALLET="EQxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
LIQUIDITY_WALLET="EQxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Allocation amounts in GSTD (script multiplies by 10^9)
TEAM_AMOUNT=100000000
ECOSYSTEM_AMOUNT=200000000
LIQUIDITY_AMOUNT=100000000

# XAUT Jetton master (tether gold) — mainnet address
XAUT_JETTON_MASTER="EQA1R_LuQCLHlMgOo1S4G7Y7W1cd0FrAkbA10Zq7rddKxi9k"

# STON.fi router — leave empty for Phase 1 (manual treasury management)
STONFI_ROUTER=""

# Network: testnet | mainnet
TON_NETWORK=testnet

# TON Center API key — free at toncenter.com
TON_API_KEY=""
