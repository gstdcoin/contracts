# GSTD Contract Deployment Environment
# Copy to .env and fill in values. NEVER commit .env.

# Deployer wallet 24-word mnemonic (the wallet that pays for deployment)
DEPLOYER_MNEMONIC="word1 word2 word3 ... word24"

# Admin wallet address (receives contract ownership; use your multisig)
ADMIN_WALLET="EQxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# TON Center API key (free at toncenter.com) — optional but prevents rate limits
TON_API_KEY=""

# XAUT Jetton Master address (real gold-backed token)
# Mainnet: EQA1R_LuQCLHlMgOo1S4G7Y7W1cd0FrAkbA10Zq7rddKxi9k
# Testnet: use a mock or leave default
XAUT_JETTON_MASTER="EQA1R_LuQCLHlMgOo1S4G7Y7W1cd0FrAkbA10Zq7rddKxi9k"

# STON.fi router address (for TreasuryGold swaps — mainnet only)
STONFI_ROUTER="EQB3nc...ston_fi_router"

# Network: testnet | mainnet  (default: testnet in deploy-testnet.ts)
TON_NETWORK=testnet
