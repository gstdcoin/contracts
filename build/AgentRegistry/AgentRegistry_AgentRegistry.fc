        $AgentRegistry$_contract_store(($self'owner, $self'settlementContract, $self'totalNodes, $self'activeNodes, $self'totalTasksCompleted, $self'genesisVersion, $self'genesisManifestHash, $self'edgeCount, $self'cpuCount, $self'gpuCount, $self'headCount));
        return ();
    }
    
    ;; Receive SetGenesisManifest message
    if (op == 2346698756) {
        var $msg'version = in_msg~load_uint(32);
        var $msg'manifestHash = in_msg~load_uint(256);
