            throw_unless(48099, ($msg'genesisHash == $self'genesisManifestHash));
        }
        var ($nodeInit'code, $nodeInit'data) = $NodeIdentity$_init_child($msg'nodeId, $global_myAddress(), __tact_context_get_sender(), $msg'nodeType, $msg'capabilities, $msg'region);
        $global_send($SendParameters$_constructor_to_value_mode_bounce_body_code_data($global_contractAddress(($nodeInit'code, $nodeInit'data)), 50000000, 2, false, __gen_cell_cell_ddd30e17762c77a8f11d9eb00b2a7b68884862497e5d710e258a5a03ceeb917d(), $nodeInit'code, $nodeInit'data));
        $self'totalNodes = ($self'totalNodes + 1);
        $self'activeNodes = ($self'activeNodes + 1);
        ifnot ($msg'nodeType) {
            $self'edgeCount = ($self'edgeCount + 1);
        }
        if (($msg'nodeType == 1)) {
            $self'cpuCount = ($self'cpuCount + 1);
        }
        if (($msg'nodeType == 2)) {
            $self'gpuCount = ($self'gpuCount + 1);
        }
        if (($msg'nodeType == 3)) {
            $self'headCount = ($self'headCount + 1);
        }
        $AgentRegistry$_contract_store(($self'owner, $self'settlementContract, $self'totalNodes, $self'activeNodes, $self'totalTasksCompleted, $self'genesisVersion, $self'genesisManifestHash, $self'edgeCount, $self'cpuCount, $self'gpuCount, $self'headCount));
        return ();
    }
    
    ;; Receive UpdateReputation message
    if (op == 2787149265) {
        var $msg'nodeId = in_msg~load_uint(256);
        var $msg'qualityDelta = in_msg~load_int(32);
        var $msg'uptimeDelta = in_msg~load_int(32);
        var $msg'tasksDelta = in_msg~load_uint(32);
        throw_unless(27658, ( (( equal_slices_bits(__tact_context_get_sender(), $self'owner) )) ? (true) : (( equal_slices_bits(__tact_context_get_sender(), $self'settlementContract) )) ));
        $self'totalTasksCompleted = ($self'totalTasksCompleted + $msg'tasksDelta);
        slice $nodeAddr = ($self'owner, $self'settlementContract, $self'totalNodes, $self'activeNodes, $self'totalTasksCompleted, $self'genesisVersion, $self'genesisManifestHash, $self'edgeCount, $self'cpuCount, $self'gpuCount, $self'headCount)~$AgentRegistry$_fun_getNodeAddress($msg'nodeId);
        $global_send($SendParameters$_constructor_to_value_mode_bounce_body($nodeAddr, 30000000, 2, false, $UpdateReputation$_store_cell(($msg'nodeId, $msg'qualityDelta, $msg'uptimeDelta, $msg'tasksDelta), begin_cell())));
        $AgentRegistry$_contract_store(($self'owner, $self'settlementContract, $self'totalNodes, $self'activeNodes, $self'totalTasksCompleted, $self'genesisVersion, $self'genesisManifestHash, $self'edgeCount, $self'cpuCount, $self'gpuCount, $self'headCount));
        return ();
    }
    
    ;; Receive ReportGenesisViolation message
    if (op == 1141050109) {
        var $msg'nodeId = in_msg~load_uint(256);
        var $msg'reporterNodeId = in_msg~load_uint(256);
        var $msg'evidenceHash = in_msg~load_uint(256);
        $self'activeNodes = ($self'activeNodes - 1);
        slice $nodeAddr = ($self'owner, $self'settlementContract, $self'totalNodes, $self'activeNodes, $self'totalTasksCompleted, $self'genesisVersion, $self'genesisManifestHash, $self'edgeCount, $self'cpuCount, $self'gpuCount, $self'headCount)~$AgentRegistry$_fun_getNodeAddress($msg'nodeId);
