    return (($self'owner, $self'settlementContract, $self'totalNodes, $self'activeNodes, $self'totalTasksCompleted, $self'genesisVersion, $self'genesisManifestHash, $self'edgeCount, $self'cpuCount, $self'gpuCount, $self'headCount), ());
