    var self = $DAOVoting$_contract_load();
    var res = self~$DAOVoting$_fun_owner();
    return res;
}

;;
;; Routing of a Contract DAOVoting
;;

;; message opcode reader utility: only binary receivers
;; Returns 32 bit message opcode, otherwise throws the "Invalid incoming message" exit code
(slice, int) ~load_opcode_internal(slice s) asm( -> 1 0) "32 LDUQ 130 THROWIFNOT";

() recv_internal(int msg_value, cell in_msg_cell, slice in_msg) impure {
    
    ;; Context
    var cs = in_msg_cell.begin_parse();
    cs~skip_bits(2);
    var msg_bounceable = cs~load_int(1);
    var msg_bounced = cs~load_int(1);
    slice msg_sender_addr = cs~load_msg_addr();
    __tact_context = (msg_bounceable, msg_sender_addr, msg_value, cs);
    __tact_context_sender = msg_sender_addr;
    
    ;; Load contract data
    var ($self'owner, $self'gstdJetton, $self'quorumPercent, $self'timelockSeconds, $self'minProposalStake, $self'totalStakedGSTD, $self'proposalCount, $self'executedCount, $self'cancelledCount) = $DAOVoting$_contract_load();
    
    ;; Handle bounced messages
    if (msg_bounced) { return (); }
    int op = 0;
    int in_msg_length = slice_bits(in_msg);
    if (in_msg_length >= 32) {
        op = in_msg~load_uint(32);
        ;; Receive CreateProposal message
        if (op == 3565067208) {
            var $msg'title = in_msg~load_ref().begin_parse();
            var $msg'descriptionHash = in_msg~load_uint(256);
            var $msg'targetContract = in_msg~load_msg_addr();
            var $msg'payload = in_msg~load_ref();
            var $msg'votingPeriod = in_msg~load_uint(32);
            int $proposalId = $self'proposalCount;
            $self'proposalCount = ($self'proposalCount + 1);
            var ($proposalInit'code, $proposalInit'data) = $Proposal$_init_child($proposalId, $global_myAddress(), __tact_context_get_sender(), $msg'targetContract, $msg'payload, $msg'votingPeriod, $self'timelockSeconds);
            $global_send($SendParameters$_constructor_to_value_mode_bounce_body_code_data($global_contractAddress(($proposalInit'code, $proposalInit'data)), 100000000, 2, false, __gen_cell_cell_ddd30e17762c77a8f11d9eb00b2a7b68884862497e5d710e258a5a03ceeb917d(), $proposalInit'code, $proposalInit'data));
            $DAOVoting$_contract_store(($self'owner, $self'gstdJetton, $self'quorumPercent, $self'timelockSeconds, $self'minProposalStake, $self'totalStakedGSTD, $self'proposalCount, $self'executedCount, $self'cancelledCount));
            return ();
        }
        
        ;; Receive ExecuteProposal message
        if (op == 2470491975) {
            var $msg'proposalId = in_msg~load_uint(64);
            $self'executedCount = ($self'executedCount + 1);
            $DAOVoting$_contract_store(($self'owner, $self'gstdJetton, $self'quorumPercent, $self'timelockSeconds, $self'minProposalStake, $self'totalStakedGSTD, $self'proposalCount, $self'executedCount, $self'cancelledCount));
            return ();
        }
        
        ;; Receive UpdateGovernanceParams message
        if (op == 2128179073) {
            var $msg'quorumPercent = in_msg~load_uint(8);
            var $msg'timelockSeconds = in_msg~load_uint(32);
            var $msg'minProposalStake = in_msg~load_varuint16();
            throw_unless(56882, ( equal_slices_bits(__tact_context_get_sender(), $self'owner) ));
            throw_unless(14831, ( (($msg'quorumPercent >= 5)) ? (($msg'quorumPercent <= 51)) : (false) ));
            $self'quorumPercent = $msg'quorumPercent;
            $self'timelockSeconds = $msg'timelockSeconds;
            $self'minProposalStake = $msg'minProposalStake;
            $DAOVoting$_contract_store(($self'owner, $self'gstdJetton, $self'quorumPercent, $self'timelockSeconds, $self'minProposalStake, $self'totalStakedGSTD, $self'proposalCount, $self'executedCount, $self'cancelledCount));
            return ();
        }
        
        ;; Receive Deploy message
        if (op == 0x946a98b6) {
            var $deploy'queryId = in_msg~load_uint(64);
            ($self'owner, $self'gstdJetton, $self'quorumPercent, $self'timelockSeconds, $self'minProposalStake, $self'totalStakedGSTD, $self'proposalCount, $self'executedCount, $self'cancelledCount)~$DAOVoting$_fun_notify($DeployOk$_store_cell($DeployOk$_constructor_queryId($deploy'queryId), begin_cell()));
            $DAOVoting$_contract_store(($self'owner, $self'gstdJetton, $self'quorumPercent, $self'timelockSeconds, $self'minProposalStake, $self'totalStakedGSTD, $self'proposalCount, $self'executedCount, $self'cancelledCount));
            return ();
        }
        
    }
    ;; Empty Receiver and Text Receivers
    var text_op = slice_hash(in_msg);
    ;; Receive "renounce" message
    if (text_op == 0x5240c307401835ee4ec0137f373534d474d56ddc78888246070a7b12c2ef6a39) {
        throw_unless(35499, ( equal_slices_bits(__tact_context_get_sender(), $self'owner) ));
        $self'owner = $global_myAddress();
        $DAOVoting$_contract_store(($self'owner, $self'gstdJetton, $self'quorumPercent, $self'timelockSeconds, $self'minProposalStake, $self'totalStakedGSTD, $self'proposalCount, $self'executedCount, $self'cancelledCount));
        return ();
    }
    ;; Throw if not handled
    throw(130);
}
