;;
;; Routing of a Contract SettlementMaster
;;

;; message opcode reader utility: only binary receivers
;; Returns 32 bit message opcode, otherwise throws the "Invalid incoming message" exit code
(slice, int) ~load_opcode_internal(slice s) asm( -> 1 0) "32 LDUQ 130 THROWIFNOT";

() recv_internal(int msg_value, cell in_msg_cell, slice in_msg) impure {
    
    ;; Context
    var cs = in_msg_cell.begin_parse();
    cs~skip_bits(2);
    var msg_bounceable = cs~load_int(1);
    var msg_bounced = cs~load_int(1);
    slice msg_sender_addr = cs~load_msg_addr();
    __tact_context = (msg_bounceable, msg_sender_addr, msg_value, cs);
    __tact_context_sender = msg_sender_addr;
    
    ;; Load contract data
    var ($self'owner, $self'gstdJetton, $self'treasury, $self'protocolFee, $self'workerShare, $self'treasuryShare, $self'protocolShare, $self'baseRate, $self'totalSettled, $self'totalGSTDMinted, $self'taskCount, $self'paused, $self'minPayment) = $SettlementMaster$_contract_load();
    
    ;; Handle bounced messages
    if (msg_bounced) {
        ;; Skip 0xFFFFFFFF prefix of a bounced message
        in_msg~skip_bits(32);
        int op = 0;
        if (slice_bits(in_msg) >= 32) {
            op = in_msg~load_uint(32);
        }
        ;; Bounced handler for WorkerPayment message
        if (op == 1500073070) {
            var ($src'taskId, $src'amount) = in_msg~$WorkerPayment$_load_bounced();
            $global_send($SendParameters$_constructor_to_value_mode_bounce_body($self'treasury, 0, 66, false, __gen_cell_cell_ebdaba3b7f6e6685e5e56535cbcbe76d7c312f6fabe26d4760c96e76e01a5dc9()));
            $SettlementMaster$_contract_store(($self'owner, $self'gstdJetton, $self'treasury, $self'protocolFee, $self'workerShare, $self'treasuryShare, $self'protocolShare, $self'baseRate, $self'totalSettled, $self'totalGSTDMinted, $self'taskCount, $self'paused, $self'minPayment));
            return ();
        }
        
        return ();
    }
    var op = in_msg~load_opcode_internal();
    ;; Receive SettleTask message
    if (op == 1462673144) {
        var $msg'taskId = in_msg~load_uint(64);
        var $msg'workerAddr = in_msg~load_msg_addr();
        var $msg'gstdBonusAmount = in_msg~load_varuint16();
        var $msg'qualityScore = in_msg~load_uint(32);
        var $msg'computeUnits = in_msg~load_uint(64);
        throw_unless(1730, ( equal_slices_bits(__tact_context_get_sender(), $self'owner) ));
        throw_unless(38610, (~ $self'paused));
        int $total = ($Context$_get_value(__tact_context_get()) - 100000000);
        throw_unless(8484, ($total >= $self'minPayment));
        int $workerAmt = (($total * $self'workerShare) / 100);
        int $treasuryAmt = (($total * $self'treasuryShare) / 100);
        int $protocolAmt = (($total - $workerAmt) - $treasuryAmt);
        $self'totalSettled = ($total + $self'totalSettled);
        $self'totalGSTDMinted = ($msg'gstdBonusAmount + $self'totalGSTDMinted);
        $self'taskCount = (1 + $self'taskCount);
        $global_send($SendParameters$_constructor_to_value_mode_bounce_body($msg'workerAddr, $workerAmt, 2, true, $WorkerPayment$_store_cell($WorkerPayment$_constructor_taskId_amount_bonusGSTD($msg'taskId, $workerAmt, $msg'gstdBonusAmount), begin_cell())));
        $global_send($SendParameters$_constructor_to_value_mode_bounce_body($self'treasury, $treasuryAmt, 2, false, __gen_cell_cell_6c7f095b2834dcd10181b530fba875659e91af767b1d084243958c07bfe40df5()));
        $global_send($SendParameters$_constructor_to_value_mode_bounce_body($self'protocolFee, $protocolAmt, 2, false, __gen_cell_cell_a537636aa5fc3c2d44d23d8823f0a46ea660ebe768ba768596c3046cd297304b()));
        if (($msg'gstdBonusAmount > 0)) {
            $global_send($SendParameters$_constructor_to_value_mode_bounce_body($self'gstdJetton, 80000000, 2, false, $MintWorkerReward$_store_cell($MintWorkerReward$_constructor_workerAddr_amount_taskId($msg'workerAddr, $msg'gstdBonusAmount, $msg'taskId), begin_cell())));
        }
        $SettlementMaster$_contract_store(($self'owner, $self'gstdJetton, $self'treasury, $self'protocolFee, $self'workerShare, $self'treasuryShare, $self'protocolShare, $self'baseRate, $self'totalSettled, $self'totalGSTDMinted, $self'taskCount, $self'paused, $self'minPayment));
        return ();
    }
    
    ;; Receive UpdateShares message
    if (op == 3201974444) {
        var $msg'worker = in_msg~load_uint(8);
        var $msg'treasury = in_msg~load_uint(8);
        var $msg'protocol = in_msg~load_uint(8);
        throw_unless(63399, ( equal_slices_bits(__tact_context_get_sender(), $self'owner) ));
        throw_unless(22722, ((($msg'worker + $msg'treasury) + $msg'protocol) == 100));
        throw_unless(45933, ($msg'worker >= 50));
        $self'workerShare = $msg'worker;
        $self'treasuryShare = $msg'treasury;
        $self'protocolShare = $msg'protocol;
        $SettlementMaster$_contract_store(($self'owner, $self'gstdJetton, $self'treasury, $self'protocolFee, $self'workerShare, $self'treasuryShare, $self'protocolShare, $self'baseRate, $self'totalSettled, $self'totalGSTDMinted, $self'taskCount, $self'paused, $self'minPayment));
        return ();
    }
    
    ;; Receive UpdateAddresses message
    if (op == 1410061209) {
        var $msg'treasury = in_msg~load_msg_addr();
        var $msg'protocolFee = in_msg~load_msg_addr();
        var $msg'gstdJetton = in_msg~load_msg_addr();
        throw_unless(63399, ( equal_slices_bits(__tact_context_get_sender(), $self'owner) ));
        $self'treasury = $msg'treasury;
        $self'protocolFee = $msg'protocolFee;
        $self'gstdJetton = $msg'gstdJetton;
        $SettlementMaster$_contract_store(($self'owner, $self'gstdJetton, $self'treasury, $self'protocolFee, $self'workerShare, $self'treasuryShare, $self'protocolShare, $self'baseRate, $self'totalSettled, $self'totalGSTDMinted, $self'taskCount, $self'paused, $self'minPayment));
        return ();
    }
    
    ;; Receive SetBaseRate message
    if (op == 3608050927) {
        var $msg'rate = in_msg~load_varuint16();
        throw_unless(63399, ( equal_slices_bits(__tact_context_get_sender(), $self'owner) ));
        throw_unless(27818, ($msg'rate > 0));
        $self'baseRate = $msg'rate;
        $SettlementMaster$_contract_store(($self'owner, $self'gstdJetton, $self'treasury, $self'protocolFee, $self'workerShare, $self'treasuryShare, $self'protocolShare, $self'baseRate, $self'totalSettled, $self'totalGSTDMinted, $self'taskCount, $self'paused, $self'minPayment));
        return ();
    }
    
    ;; Receive EmergencyPause message
    if (op == 1064338113) {
        var $msg'paused = in_msg~load_int(1);
        throw_unless(63399, ( equal_slices_bits(__tact_context_get_sender(), $self'owner) ));
        $self'paused = $msg'paused;
        $SettlementMaster$_contract_store(($self'owner, $self'gstdJetton, $self'treasury, $self'protocolFee, $self'workerShare, $self'treasuryShare, $self'protocolShare, $self'baseRate, $self'totalSettled, $self'totalGSTDMinted, $self'taskCount, $self'paused, $self'minPayment));
        return ();
    }
    
    ;; Receive Deploy message
    if (op == 0x946a98b6) {
        var $deploy'queryId = in_msg~load_uint(64);
        ($self'owner, $self'gstdJetton, $self'treasury, $self'protocolFee, $self'workerShare, $self'treasuryShare, $self'protocolShare, $self'baseRate, $self'totalSettled, $self'totalGSTDMinted, $self'taskCount, $self'paused, $self'minPayment)~$SettlementMaster$_fun_notify($DeployOk$_store_cell($DeployOk$_constructor_queryId($deploy'queryId), begin_cell()));
        $SettlementMaster$_contract_store(($self'owner, $self'gstdJetton, $self'treasury, $self'protocolFee, $self'workerShare, $self'treasuryShare, $self'protocolShare, $self'baseRate, $self'totalSettled, $self'totalGSTDMinted, $self'taskCount, $self'paused, $self'minPayment));
        return ();
    }
    
    ;; Throw if not handled
    throw(130);
}
