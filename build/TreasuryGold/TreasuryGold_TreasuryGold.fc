            $self'totalOperationalSpent = ($self'totalOperationalSpent + $msg'amount);
            $global_send($SendParameters$_constructor_to_value_mode_bounce_body($msg'destination, $msg'amount, 2, false, __gen_cell_cell_1868460c2e86354b306ee4b78d9812bd36c69d04720d4d182ccf77e0dc17a94a()));
            $TreasuryGold$_contract_store(($self'owner, $self'xautJetton, $self'dexRouter, $self'goldReserveXAUt, $self'totalTONReceived, $self'totalTONConvertedToGold, $self'totalOperationalSpent, $self'goldConvertRatio, $self'depositCount, $self'lastDepositTime));
            return ();
        }
        
        ;; Receive SetConvertRatio message
        if (op == 3740403761) {
            var $msg'ratio = in_msg~load_uint(8);
            throw_unless(63399, ( equal_slices_bits(__tact_context_get_sender(), $self'owner) ));
            throw_unless(60938, ( (($msg'ratio >= 50)) ? (($msg'ratio <= 95)) : (false) ));
            $self'goldConvertRatio = $msg'ratio;
            $TreasuryGold$_contract_store(($self'owner, $self'xautJetton, $self'dexRouter, $self'goldReserveXAUt, $self'totalTONReceived, $self'totalTONConvertedToGold, $self'totalOperationalSpent, $self'goldConvertRatio, $self'depositCount, $self'lastDepositTime));
            return ();
        }
        
        ;; Receive SetDexRouter message
        if (op == 2701254185) {
            var $msg'router = in_msg~load_msg_addr();
            throw_unless(63399, ( equal_slices_bits(__tact_context_get_sender(), $self'owner) ));
            $self'dexRouter = $msg'router;
            $TreasuryGold$_contract_store(($self'owner, $self'xautJetton, $self'dexRouter, $self'goldReserveXAUt, $self'totalTONReceived, $self'totalTONConvertedToGold, $self'totalOperationalSpent, $self'goldConvertRatio, $self'depositCount, $self'lastDepositTime));
            return ();
        }
        
        ;; Receive SetXautJetton message
        if (op == 3103292198) {
            var $msg'xautAddr = in_msg~load_msg_addr();
            throw_unless(63399, ( equal_slices_bits(__tact_context_get_sender(), $self'owner) ));
            $self'xautJetton = $msg'xautAddr;
            $TreasuryGold$_contract_store(($self'owner, $self'xautJetton, $self'dexRouter, $self'goldReserveXAUt, $self'totalTONReceived, $self'totalTONConvertedToGold, $self'totalOperationalSpent, $self'goldConvertRatio, $self'depositCount, $self'lastDepositTime));
            return ();
        }
        
        ;; Receive Deploy message
        if (op == 0x946a98b6) {
            var $deploy'queryId = in_msg~load_uint(64);
            ($self'owner, $self'xautJetton, $self'dexRouter, $self'goldReserveXAUt, $self'totalTONReceived, $self'totalTONConvertedToGold, $self'totalOperationalSpent, $self'goldConvertRatio, $self'depositCount, $self'lastDepositTime)~$TreasuryGold$_fun_notify($DeployOk$_store_cell($DeployOk$_constructor_queryId($deploy'queryId), begin_cell()));
            $TreasuryGold$_contract_store(($self'owner, $self'xautJetton, $self'dexRouter, $self'goldReserveXAUt, $self'totalTONReceived, $self'totalTONConvertedToGold, $self'totalOperationalSpent, $self'goldConvertRatio, $self'depositCount, $self'lastDepositTime));
            return ();
        }
        
    }
    ;; Empty Receiver and Text Receivers
    var text_op = slice_hash(in_msg);
    ;; Receive "deposit" message
    if (text_op == 0x66d23e7744329745f6f26d2907874b52b0232e43983b1c95de8dc315bb45ba1f) {
        int $amount = ($Context$_get_value(__tact_context_get()) - 50000000);
        throw_unless(7620, ($amount > 0));
        $self'totalTONReceived = ($self'totalTONReceived + $amount);
        $self'depositCount = ($self'depositCount + 1);
        $self'lastDepositTime = $global_now();
        int $goldAmt = (($amount * $self'goldConvertRatio) / 100);
        int $operAmt = ($amount - $goldAmt);
        if (($goldAmt > 500000000)) {
            $global_send($SendParameters$_constructor_to_value_mode_bounce_body($self'dexRouter, $goldAmt, 2, true, __gen_cell_cell_e45e11cc3702e1e31ad0dfad26468927b83862cc71da62bdfea10a73c0f45a7e()));
            $self'totalTONConvertedToGold = ($self'totalTONConvertedToGold + $goldAmt);
        }
        $TreasuryGold$_contract_store(($self'owner, $self'xautJetton, $self'dexRouter, $self'goldReserveXAUt, $self'totalTONReceived, $self'totalTONConvertedToGold, $self'totalOperationalSpent, $self'goldConvertRatio, $self'depositCount, $self'lastDepositTime));
        return ();
    }
    ;; Throw if not handled
    throw(130);
}
