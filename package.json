{
    "name": "gstd-contracts",
    "version": "1.0.0",
    "description": "GSTD TON Smart Contract Deployment",
    "scripts": {
        "build": "./node_modules/.bin/tact --config tact.config.json",
        "deploy:testnet": "TON_NETWORK=testnet npx ts-node --project tsconfig.deploy.json scripts/deploy-testnet.ts",
        "deploy:mainnet": "TON_NETWORK=mainnet npx ts-node --project tsconfig.deploy.json scripts/deploy-mainnet.ts",
        "verify": "node scripts/verify-contracts.js",
        "settle": "npx ts-node --project tsconfig.deploy.json scripts/settle-rewards.ts"
    },
    "dependencies": {
        "@tact-lang/compiler": "^1.5.0",
        "@ton/core": "^0.62.0",
        "@ton/crypto": "^3.3.0",
        "@ton/ton": "^15.0.0",
        "dotenv": "^16.4.0"
    },
    "devDependencies": {
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    }
}
