{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "moduleResolution": "node",
        "ignoreDeprecations": "6.0",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "outDir": "./dist-deploy"
    },
    "include": ["scripts/*.ts", "build/**/*.ts"]
}
